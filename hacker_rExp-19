#include <sstream>
#include <vector>
#include <iostream>

using namespace std;

vector<int> parseInts(string str) {
    vector<int> result;
    stringstream ss(str);
    int temp;
    char ch;

    // Keep reading an integer as long as one is available
    while (ss >> temp) {
        result.push_back(temp);
        // Try to read the comma; if it's the end of the string, this simply fails
        ss >> ch;
    }
    
    return result;
}

int main() {
    string str;
    cin >> str;
    vector<int> integers = parseInts(str);
    for(int i = 0; i < integers.size(); i++) {
        cout << integers[i] << "\n";
    }
    
    return 0;
}
