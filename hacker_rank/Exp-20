#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int n;
    // 1. Read the number of elements
    if (!(cin >> n)) return 0; 
    
    // 2. Read the elements into a vector
    vector<int> arr(n);
    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }
    
    // 3. Sort the vector using the <algorithm> library
    sort(arr.begin(), arr.end());
    
    // 4. Print the sorted elements separated by spaces
    for(int i = 0; i < n; i++) {
        cout << arr[i] << (i == n - 1 ? "" : " ");
    }
    
    return 0;
}
